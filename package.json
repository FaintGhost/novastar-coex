    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ky": "^1.14.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.4",
    "tsgolint": "^0.0.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
