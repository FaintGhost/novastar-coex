{
  "name": "@novastar-dev/coex",
  "version": "2.0.3",
  "description": "A javascript library for control of NovaStar COEX video wall processors",
  "keywords": [
    "coex",
    "led",
    "novastar",
    "video",
    "wall"
  ],
  "homepage": "https://github.com/FaintGhost/novastar-coex",
  "bugs": {
    "url": "https://github.com/FaintGhost/novastar-coex/issues"
  },
  "license": "MIT",
  "author": "FaintGhost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FaintGhost/novastar-coex.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
